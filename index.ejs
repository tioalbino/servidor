const express = require('express');
const session = require('express-session');
const http = require('http');
const socketIO = require('socket.io');
const pty = require('node-pty');
const path = require('path');

const app = express();
const server = http.createServer(app);
const io = socketIO(server);

const sessionMiddleware = session({
    secret: 'chave-ultra-secreta',
    resave: false,
    saveUninitialized: false,
    cookie: { maxAge: 3600000 } // 1 hora de sessão
});

app.use(sessionMiddleware);
app.use(express.urlencoded({ extended: true }));

// Rota de login
app.get('/login', (req, res) => {
    res.send(`
        <body style="background:#1a1a1a; color:white; font-family:sans-serif; display:flex; justify-content:center; align-items:center; height:100vh;">
            <form action="/login" method="POST" style="background:#333; padding:20px; border-radius:8px;">
                <h2>Ubuntu Web Terminal</h2>
                <input name="user" placeholder="Usuário" style="display:block; margin-bottom:10px; width:100%""")/>>
                <input name="pass" type="password" placeholder="Senha" style="display:block; margin-bottom:10px; width:100%""")/>>
                <button type="submit" style="width:100%; cursor:pointer">Entrar</button>
            </form>
        </body>
    `);
});

app.post('/login', (req, res) => {
    if (req.body.user === 'admin' && req.body.pass === 'suasenha') {
        req.session.authenticated = true;
        res.redirect('/');
    } else {
        res.send('Acesso negado.');
    }
});

app.get('/', (req, res) => {
    if (!req.session.authenticated) return res.redirect('/login');
    res.sendFile(path.join(__dirname, 'index.html'));
});

// Integração Socket.io com PTY
io.use((socket, next) => { sessionMiddleware(socket.request, {}, next); });

io.on('connection', (socket) => {
    if (!socket.request.session.authenticated) return socket.disconnect();

    // Cria o terminal real com suporte a cores e tamanho inicial
    const shell = pty.spawn('bash', [], {
        name: 'xterm-256color',
        cols: 80,
        rows: 24,
        cwd: process.env.HOME,
        env: process.env
    });

    // Envia dados do Ubuntu para o Navegador
    shell.onData(data => socket.emit('output', data));

    // Recebe comandos do Navegador
    socket.on('input', data => shell.write(data));

    // Ajusta o tamanho do terminal quando o usuário redimensiona a janela
    socket.on('resize', size => {
        shell.resize(size.cols, size.rows);
    });

    socket.on('disconnect', () => shell.kill());
});

server.listen(3000, () => console.log('Terminal Forte rodando em http://localhost:3000'));
